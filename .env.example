# --- Qwen HTTP service (qwen_service/run_server.py) ---
QWEN_HOST=127.0.0.1
QWEN_PORT=30078
QWEN_MODEL_PATH=Qwen2.5-VL-7B-Instruct
QWEN_DEVICE=cuda:0
QWEN_MAX_NEW_TOKENS=768
QWEN_TEMPERATURE=0.0
QWEN_MAX_IMAGE_LONG_SIDE=1024

# --- Gateway: URL used to call Qwen ---
QWEN_BASE_URL=http://127.0.0.1:30078

# --- Pipeline / gateway flags ---
USE_QWEN_SCENE_ONLY=true
DEBUG_SAVE_ARTIFACTS=true

# --- Gateway bind (run_backend.py / PM2) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=30079

PYTHONUNBUFFERED=1
